{
  "name": "auto-recruit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24 <27"
  },
  "scripts": {
    "dev": "node --import ./scripts/node-ts-hooks.mjs src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:scoring && npm run test:export && npm run test:maintenance",
    "test:scoring": "node --import ./scripts/node-ts-hooks.mjs --test src/scripts/test-jd-parser.ts src/scripts/test-jd-rag.ts src/scripts/test-rag-answer-eval.ts src/scripts/test-rag-api.ts src/scripts/test-rag-doctor.ts src/scripts/test-rag-doctor-batch.ts src/scripts/test-rag-eval.ts src/scripts/test-rag-export-answer-eval.ts src/scripts/test-rag-feedback.ts src/scripts/test-rag-hybrid-search.ts src/scripts/test-rag-ingest-conversations.ts src/scripts/test-rag-inspect.ts src/scripts/test-rag-metrics.ts src/scripts/test-rag-ops-report.ts src/scripts/test-rag-regression.ts src/scripts/test-rag-review.ts src/scripts/test-rag-review-batch.ts src/scripts/test-rag-service.ts src/scripts/test-score-schema.ts src/scripts/test-score-prompt.ts src/scripts/test-scoring-run-semantics.ts src/scripts/test-search-subscription.ts src/scripts/test-score-stored-resumes.ts src/scripts/test-platform-registry.ts src/scripts/test-node-ts-hooks.ts src/scripts/test-discover-search-filters.ts src/scripts/test-filter-input-pool.ts",
    "test:rag:offline": "npm run rag:baseline:offline -- --summary-only true",
    "test:export": "node --import ./scripts/node-ts-hooks.mjs --test src/scripts/test-aggregate-results.ts src/scripts/test-export-job-results.ts src/scripts/test-export-resume-docx.ts src/scripts/test-export-filter-input-pools.ts src/scripts/test-export-filter-input-mapping.ts src/scripts/test-export-filter-single-select-mapping.ts src/scripts/test-export-filter-cascade-mapping.ts src/scripts/test-export-filter-catalog-html.ts src/scripts/test-export-application-filter-options.ts src/scripts/test-validate-application-filter-input.ts src/scripts/test-verify-liepin-application-filter-options.ts src/scripts/test-51job-filter-fixtures.ts src/scripts/test-liepin-filter-normalization.ts",
    "test:maintenance": "node --import ./scripts/node-ts-hooks.mjs --test src/scripts/test-migrate-platform-storage.ts src/scripts/test-send-job-report-email.ts",
    "test:experimental:liepin": "node --import ./scripts/node-ts-hooks.mjs --test src/scripts/test-liepin-adapter.ts src/scripts/test-smoke-liepin-flow.ts",
    "test:experimental:zhilian": "node --import ./scripts/node-ts-hooks.mjs --test src/scripts/test-zhilian-adapter.ts",
    "score:stored": "node --import ./scripts/node-ts-hooks.mjs src/scripts/score-stored-resumes.ts",
    "export:results": "node --import ./scripts/node-ts-hooks.mjs src/scripts/export-job-results.ts",
    "export:resume-docx": "node --import ./scripts/node-ts-hooks.mjs src/scripts/export-resume-docx.ts",
    "migrate:platform-storage": "node --import ./scripts/node-ts-hooks.mjs src/scripts/migrate-platform-storage.ts",
    "start": "node dist/index.js",
    "reparse:resumes": "node --import ./scripts/node-ts-hooks.mjs src/scripts/reparse-resumes.ts",
    "validate:resumes": "node --import ./scripts/node-ts-hooks.mjs src/scripts/validate-resume-extraction.ts",
    "capture:resume-dom": "node --import ./scripts/node-ts-hooks.mjs src/scripts/capture-resume-dom-snapshot.ts",
    "login:session": "node --import ./scripts/node-ts-hooks.mjs src/scripts/login-and-save-session.ts",
    "discover:filters": "node --import ./scripts/node-ts-hooks.mjs src/scripts/discover-search-filters.ts",
    "discover:liepin-industry-tree": "node --import ./scripts/node-ts-hooks.mjs src/scripts/discover-liepin-industry-tree.ts",
    "validate:filter-input": "node --import ./scripts/node-ts-hooks.mjs src/scripts/validate-application-filter-input.ts",
    "verify:liepin-filter-options": "node --import ./scripts/node-ts-hooks.mjs src/scripts/verify-liepin-application-filter-options.ts",
    "rag:index": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-index.ts",
    "rag:api": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-api.ts",
    "rag:ask": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-ask.ts",
    "rag:baseline": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-baseline.ts",
    "rag:baseline:offline": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-baseline-offline.ts",
    "rag:answer-eval": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-answer-eval.ts",
    "rag:doctor": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-doctor.ts",
    "rag:doctor:batch": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-doctor-batch.ts",
    "rag:eval": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-eval.ts",
    "rag:export-answer-eval": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-export-answer-eval.ts",
    "rag:feedback": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-feedback.ts",
    "rag:embedding:local": ".venv/bin/python scripts/local_embedding_server.py",
    "rag:ingest-conversation": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-ingest-conversation.ts",
    "rag:ingest-conversations": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-ingest-conversations.ts",
    "rag:inspect": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-inspect.ts",
    "rag:metrics": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-metrics.ts",
    "rag:ops": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-ops-report.ts",
    "rag:regression": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-regression.ts",
    "rag:review": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-review.ts",
    "rag:review:batch": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-review-batch.ts",
    "rag:rebuild": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-rebuild.ts",
    "rag:seed-fixtures": "node --import ./scripts/node-ts-hooks.mjs src/scripts/rag-seed-fixtures.ts",
    "debug:liepin-forward": "node --import ./scripts/node-ts-hooks.mjs src/scripts/debug-liepin-forward-contact.ts",
    "debug:zhilian": "node --import ./scripts/node-ts-hooks.mjs src/scripts/debug-zhilian-search-state.ts",
    "smoke:liepin": "node --import ./scripts/node-ts-hooks.mjs src/scripts/smoke-liepin-flow.ts",
    "smoke:zhilian": "node --import ./scripts/node-ts-hooks.mjs src/scripts/smoke-zhilian-flow.ts"
  },
  "dependencies": {
    "cheerio": "1.0.0-rc.12",
    "cloakbrowser": "^0.3.31",
    "dotenv": "^16.4.5",
    "jszip": "^3.10.1",
    "nodemailer": "^8.0.10",
    "openai": "^6.37.0",
    "playwright": "^1.59.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/nodemailer": "^8.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2"
  }
}
