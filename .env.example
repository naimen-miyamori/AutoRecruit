# Storage and browser
DATA_DIR=./data
BROWSER_ENGINE=cloakbrowser
PLAYWRIGHT_HEADLESS=false
# Leave unset to use platform-specific storage-state files.
# STORAGE_STATE_PATH=
# Boss search keywords, direct chat text, and remarks type one grapheme at a time.
# PLAYWRIGHT_BOSS_TYPING_DELAY_MIN_MS=80
# PLAYWRIGHT_BOSS_TYPING_DELAY_MAX_MS=180

# OpenAI-compatible API (required for JD parsing and resume scoring)
OPENAI_API_KEY=your-openai-api-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=your-model-name
# Optional model overrides. When empty, OPENAI_MODEL is used.
# JD_PARSING_MODEL=
# SCORING_MODEL=

# Qdrant and RAG
QDRANT_URL=http://127.0.0.1:6333
# QDRANT_API_KEY=
RAG_VECTOR_COLLECTION=autorecruit_rag_chunks
RAG_EMBEDDING_PROVIDER=local-http
RAG_EMBEDDING_LOCAL_URL=http://127.0.0.1:8011
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# RAG_EMBEDDING_LOCAL_API_KEY=
# RAG_MODEL=
RAG_TOP_K=8
RAG_RETRIEVAL_MODE=hybrid
# RAG_DENSE_TOP_K=32
# RAG_KEYWORD_TOP_K=32
# RAG_RERANK_CANDIDATE_K=24
RAG_MIN_CONFIDENCE_SCORE=0.08

# SMTP report delivery
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM=your-sender@example.com

# Optional RAG HTTP API
# RAG_API_HOST=127.0.0.1
# RAG_API_PORT=3978
# RAG_API_KEY=your-rag-api-key
# RAG_API_MAX_BODY_BYTES=1048576

# Optional console HTTP API
# AUTORECRUIT_CONSOLE_HOST=127.0.0.1
# AUTORECRUIT_CONSOLE_PORT=4180
# AUTORECRUIT_CONSOLE_API_KEY=your-console-api-key
# AUTORECRUIT_CONSOLE_MAX_BODY_BYTES=2097152
# AUTORECRUIT_CONSOLE_FRONTEND_DIR=./frontend/dist

# Optional frontend API base URL (defaults to /api)
# VITE_API_BASE_URL=/api

# Optional Stitch integration
# STITCH_API_KEY=your-stitch-api-key
